PREFIX acr: <https://example.org/acr#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?departmentLabel ?code ?title
WHERE {
  ?course a acr:Course ;
          acr:courseCode ?code ;
          acr:courseTitle ?title ;
          acr:offeredBy ?department .
  ?department rdfs:label ?departmentLabel .
}
ORDER BY ?departmentLabel ?code

