ex:course_AI401 a acr:Course ;
    acr:courseCode "AI401" ;
    acr:courseTitle "Artificial Intelligence" ;
    acr:coversTopic ex:topic_Artificial_Intelligence,
        ex:topic_Search ;
    acr:credits 6 ;
    acr:developsSkill ex:skill_Knowledge_Representation,
        ex:skill_Reasoning ;
    acr:hasPrerequisite ex:course_CS201 ;
    acr:level 4 ;
    acr:offeredBy ex:department_Computer_Science ;
    acr:taughtBy ex:instructor_Dr_Deniz_Arslan .

ex:course_KE402 a acr:Course ;
