@prefix acr: <https://example.org/acr#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

acr: a owl:Ontology ;
    dcterms:title "Smart Academic Course Recommendation Ontology" ;
    dcterms:description "An ontology for modeling courses, students, prerequisites, skills, and academic recommendations." ;
    dcterms:creator "Project Team" ;
    dcterms:created "2026-06-17"^^xsd:date ;
    owl:versionInfo "0.2.0" .

acr:Course a owl:Class ;
    rdfs:label "Course" ;
    rdfs:comment "A university course offered by a department." .

acr:Student a owl:Class ;
    rdfs:label "Student" ;
    rdfs:comment "A learner receiving course recommendations." .

acr:Instructor a owl:Class ;
    rdfs:label "Instructor" .

acr:Department a owl:Class ;
    rdfs:label "Department" .

acr:Skill a owl:Class ;
    rdfs:label "Skill" .

acr:Topic a owl:Class ;
    rdfs:label "Topic" .

acr:Recommendation a owl:Class ;
    rdfs:label "Recommendation" ;
    rdfs:comment "A recommendation connecting a student to a course with an explanation." .

acr:DataSource a owl:Class ;
    rdfs:label "Data Source" ;
    rdfs:comment "A dataset, document, API, or catalog used to populate the knowledge graph." .

acr:ResearchStudy a owl:Class ;
    rdfs:label "Research Study" ;
    rdfs:comment "A research work used to guide ontology, reasoning, data processing, or LLM integration decisions." .

acr:StudentBehaviorSignal a owl:Class ;
    rdfs:label "Student Behavior Signal" ;
    rdfs:comment "An observable student-related signal such as completed courses, interests, or target skills." .

acr:offeredBy a owl:ObjectProperty ;
    rdfs:domain acr:Course ;
    rdfs:range acr:Department ;
    rdfs:label "offered by" .

acr:taughtBy a owl:ObjectProperty ;
    rdfs:domain acr:Course ;
    rdfs:range acr:Instructor ;
    rdfs:label "taught by" .

acr:hasPrerequisite a owl:ObjectProperty ;
    rdfs:domain acr:Course ;
    rdfs:range acr:Course ;
    rdfs:label "has prerequisite" .

acr:coversTopic a owl:ObjectProperty ;
    rdfs:domain acr:Course ;
    rdfs:range acr:Topic ;
    rdfs:label "covers topic" .

acr:developsSkill a owl:ObjectProperty ;
    rdfs:domain acr:Course ;
    rdfs:range acr:Skill ;
    rdfs:label "develops skill" .

acr:completedCourse a owl:ObjectProperty ;
    rdfs:domain acr:Student ;
    rdfs:range acr:Course ;
    rdfs:label "completed course" .

acr:interestedIn a owl:ObjectProperty ;
    rdfs:domain acr:Student ;
    rdfs:range acr:Topic ;
    rdfs:label "interested in" .

acr:recommendedCourse a owl:ObjectProperty ;
    rdfs:domain acr:Recommendation ;
    rdfs:range acr:Course ;
    rdfs:label "recommended course" .

acr:recommendedFor a owl:ObjectProperty ;
    rdfs:domain acr:Recommendation ;
    rdfs:range acr:Student ;
    rdfs:label "recommended for" .

acr:derivedFromSource a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range acr:DataSource ;
    rdfs:label "derived from source" .

acr:informedByStudy a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:range acr:ResearchStudy ;
    rdfs:label "informed by study" .

acr:hasBehaviorSignal a owl:ObjectProperty ;
    rdfs:domain acr:Student ;
    rdfs:range acr:StudentBehaviorSignal ;
    rdfs:label "has behavior signal" .

acr:courseCode a owl:DatatypeProperty ;
    rdfs:domain acr:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course code" .

acr:courseTitle a owl:DatatypeProperty ;
    rdfs:domain acr:Course ;
    rdfs:range xsd:string ;
    rdfs:label "course title" .

acr:credits a owl:DatatypeProperty ;
    rdfs:domain acr:Course ;
    rdfs:range xsd:integer ;
    rdfs:label "credits" .

acr:level a owl:DatatypeProperty ;
    rdfs:domain acr:Course ;
    rdfs:range xsd:integer ;
    rdfs:label "course level" .

acr:explanation a owl:DatatypeProperty ;
    rdfs:domain acr:Recommendation ;
    rdfs:range xsd:string ;
    rdfs:label "explanation" .

acr:confidenceScore a owl:DatatypeProperty ;
    rdfs:domain acr:Recommendation ;
    rdfs:range xsd:decimal ;
    rdfs:label "confidence score" .

acr:sourceName a owl:DatatypeProperty ;
    rdfs:domain acr:DataSource ;
    rdfs:range xsd:string ;
    rdfs:label "source name" .

acr:sourceFormat a owl:DatatypeProperty ;
    rdfs:domain acr:DataSource ;
    rdfs:range xsd:string ;
    rdfs:label "source format" .

acr:signalType a owl:DatatypeProperty ;
    rdfs:domain acr:StudentBehaviorSignal ;
    rdfs:range xsd:string ;
    rdfs:label "signal type" .

acr:signalValue a owl:DatatypeProperty ;
    rdfs:domain acr:StudentBehaviorSignal ;
    rdfs:range xsd:string ;
    rdfs:label "signal value" .
